# ── Supabase ──────────────────────────────────────────────────────────────
# Laissez ces valeurs VIDES pour faire tourner le site en mode démo (seed Pontoise
# servi par le front-end). Le site est 100% fonctionnel sans Supabase.
#
# Renseignez-les pour brancher l'authentification de l'espace pro et les données
# réelles (les vues d'agrégats remplacent alors automatiquement le seed).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Côté serveur / Edge Functions uniquement — NE JAMAIS exposer au client.
SUPABASE_SERVICE_ROLE_KEY=
